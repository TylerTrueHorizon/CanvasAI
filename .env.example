# Server-only — never expose in the browser
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Optional: after each /api/draw, log raw LLM text + validated coordinates to the server terminal.
# COORD_DEBUG_MAX=8000   max pairs to print (default); use 0 for unlimited (huge logs).
# COORD_DEBUG_RAW_PREVIEW=600   first N chars of raw model output (0 to disable preview).
